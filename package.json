{
  "name": "homedecor-ai-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "dev": "NODE_ENV=development npm run build && npm run start",
    "typecheck": "tsc --noEmit",
    "test:seed-shape": "tsx --test src/lib/inspiration/seedShape.test.ts",
    "test:inspiration": "tsx --test src/lib/inspiration/seedShape.test.ts src/lib/inspiration/schemas.test.ts",
    "test:object-inspiration": "PORT=3000 REPLICATE_API_TOKEN=test FAL_AI_API_KEY=test FIREBASE_SERVICE_ACCOUNT_KEY=$(printf '{\"project_id\":\"t\",\"private_key\":\"k\",\"client_email\":\"e\"}' | base64) AWS_S3_BUCKET=bucket AWS_S3_REGION=us-east-1 AWS_COGNITO_IDENTITY_POOL_ID=us-east-1:00000000-0000-0000-0000-000000000000 AWS_CLOUDFRONT_HOST=cdn.test.local tsx --test src/lib/objectInspiration/seedShape.test.ts src/lib/objectInspiration/schemas.test.ts scripts/seed-object-inspirations.test.ts",
    "seed:object-inspirations": "tsx scripts/seed-object-inspirations.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity": "^3.1029.0",
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/s3-request-presigner": "^3",
    "@fal-ai/client": "^1",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^9",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@google-cloud/tasks": "^5.5.2",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5",
    "firebase-admin": "^13",
    "google-auth-library": "^9.15.1",
    "pino": "^9",
    "replicate": "^1",
    "sharp": "^0.33.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "esbuild": "^0.25.0",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=24"
  }
}
