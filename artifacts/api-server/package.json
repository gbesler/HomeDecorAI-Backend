    "fastify-plugin": "^5",
    "firebase-admin": "^13",
    "pino": "^9",
    "replicate": "^1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
