# Required
PORT=3000
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FAL_AI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FIREBASE_SERVICE_ACCOUNT_KEY=<base64-encoded-firebase-service-account-json>
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=eu-central-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
LOG_LEVEL=info
NODE_ENV=development

# Interior prompt rewrite safety valves (D17 F2)
# Flip these at runtime to roll back without a code deploy.
# PROMPT_BUILDER_VERSION=v1        # "v1" (default, new modular builder) | "legacy" (wrapped old template)
# DICTIONARY_STRICT_MODE=strict    # "strict" (default, crash on incomplete dict) | "degraded" (log + use runtime fallback)
