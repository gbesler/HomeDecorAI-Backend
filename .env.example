# Required
PORT=3000
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FAL_AI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
FIREBASE_SERVICE_ACCOUNT_KEY=<base64-encoded-firebase-service-account-json>

# Async generation pipeline (Cloud Tasks) — required; the async path is the
# sole generation pipeline. GCP_PROJECT_ID must equal the project_id embedded
# in GOOGLE_APPLICATION_CREDENTIALS (cross-checked at boot).
GOOGLE_APPLICATION_CREDENTIALS=<base64-encoded-gcp-service-account-json>
GCP_PROJECT_ID=your-gcp-project-id
GCP_SERVICE_ACCOUNT_EMAIL=cloud-tasks-invoker@your-gcp-project-id.iam.gserviceaccount.com
BACKEND_PUBLIC_URL=https://your-backend.onrender.com
INTERNAL_TASK_AUDIENCE=https://your-backend.onrender.com/internal/process-generation
# GCP_LOCATION=us-central1          # optional, defaults to us-central1
# GCP_QUEUE_NAME=design-generation  # optional, defaults to design-generation

# Optional
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
LOG_LEVEL=info
NODE_ENV=development

# Interior prompt rewrite safety valves (D17 F2)
# Flip these at runtime to roll back without a code deploy.
# PROMPT_BUILDER_VERSION=v1        # "v1" (default, new modular builder) | "legacy" (wrapped old template)
# DICTIONARY_STRICT_MODE=strict    # "strict" (default, crash on incomplete dict) | "degraded" (log + use runtime fallback)
